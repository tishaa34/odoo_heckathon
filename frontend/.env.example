# ─── TransitOps Frontend environment ───────────────────────────
# Base URL the browser uses to reach the API.
# Leave as the relative default in Docker (nginx proxies /api → backend).
# For local `npm run dev`, the Vite dev server proxies /api to the target below.
VITE_API_URL=/api/v1

# Dev-only: where the Vite dev-server proxy forwards /api requests.
VITE_PROXY_TARGET=http://localhost:4000
