// TransitOps — data model. Single source of truth for the operations platform.
// UUID PKs, timestamps everywhere, FKs + indexes, enums for state, Decimal for money/weight.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  PENDING
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  TOLL
  MISC
}

// ─────────────────────────── Models ──────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  createdTrips  Trip[]         @relation("TripCreatedBy")
  tripChanges   TripStatusHistory[]
  auditLogs     AuditLog[]

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  make               String
  model              String
  year               Int?
  capacityKg         Decimal       @db.Decimal(10, 2)
  odometerKm         Decimal       @default(0) @db.Decimal(12, 2)
  acquisitionCost    Decimal       @default(0) @db.Decimal(12, 2)
  status             VehicleStatus @default(AVAILABLE)
  isRetired          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  documents       VehicleDocument[]

  @@index([status])
  @@index([registrationNumber])
  @@map("vehicles")
}

model Driver {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  phone         String
  licenseNumber String       @unique
  licenseExpiry DateTime
  status        DriverStatus @default(AVAILABLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  trips Trip[]

  @@index([status])
  @@index([licenseExpiry])
  @@map("drivers")
}

model Trip {
  id             String     @id @default(uuid())
  vehicleId      String
  driverId       String
  origin         String
  destination    String
  cargoWeightKg  Decimal    @db.Decimal(10, 2)
  distanceKm     Decimal?   @db.Decimal(10, 2)
  revenue        Decimal    @default(0) @db.Decimal(12, 2)
  status         TripStatus @default(PENDING)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vehicle   Vehicle             @relation(fields: [vehicleId], references: [id])
  driver    Driver              @relation(fields: [driverId], references: [id])
  createdBy User                @relation("TripCreatedBy", fields: [createdById], references: [id])
  history   TripStatusHistory[]
  fuelLogs  FuelLog[]
  expenses  Expense[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@map("trips")
}

model TripStatusHistory {
  id          String      @id @default(uuid())
  tripId      String
  fromStatus  TripStatus?
  toStatus    TripStatus
  reason      String?
  changedById String?
  createdAt   DateTime    @default(now())

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id])

  @@index([tripId])
  @@map("trip_status_history")
}

model MaintenanceLog {
  id          String            @id @default(uuid())
  vehicleId   String
  type        String
  description String?
  cost        Decimal           @default(0) @db.Decimal(12, 2)
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now())
  closedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id         String   @id @default(uuid())
  vehicleId  String
  tripId     String?
  liters     Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(12, 2)
  odometerKm Decimal? @db.Decimal(12, 2)
  filledAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
  @@map("fuel_logs")
}

model Expense {
  id         String          @id @default(uuid())
  vehicleId  String?
  tripId     String?
  category   ExpenseCategory
  amount     Decimal         @db.Decimal(12, 2)
  note       String?
  incurredAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
  @@index([category])
  @@map("expenses")
}

model VehicleDocument {
  id             String    @id @default(uuid())
  vehicleId      String
  type           String
  documentNumber String
  expiryDate     DateTime?
  fileUrl        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_documents")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}
