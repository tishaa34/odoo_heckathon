# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ────────────────────────────────────
# When running via docker-compose the host is the service name "db".
POSTGRES_USER=transitops
POSTGRES_PASSWORD=transitops_secret
POSTGRES_DB=transitops
DATABASE_URL=postgresql://transitops:transitops_secret@localhost:5432/transitops?schema=public

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
CORS_ORIGINS=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
